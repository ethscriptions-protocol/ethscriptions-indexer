*.dump

# Scripts (not needed in image)
script/

# Rails credentials (not used)
config/master.key
config/credentials.yml.enc
config/credentials/

# TLS certificates (passed via metadata, not baked in image)
certs/
*.key
*.crt
*.pem

scratch/
