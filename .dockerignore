# Git
.git
.gitignore

# Logs
log/*
tmp/*

# Local dev files
.env*
!.env.example
.ruby-version
.ruby-gemset

# IDE
.idea
.vscode
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Test files
spec/
coverage/

# Documentation
*.md
!README.md

